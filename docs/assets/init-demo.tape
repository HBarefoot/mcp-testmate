# Recorded with charmbracelet/vhs — see record-demos.sh for the full setup.
Output init-demo.gif

Set Shell bash
Set FontSize 14
Set Width 700
Set Height 460
Set Padding 12
Set WindowBar Colorful
Set TypingSpeed 40ms
Set Framerate 20

Hide
Type "export PATH=/tmp/mcp-testmate-vhs/bin:$PATH && cd /tmp/mcp-testmate-vhs/init-demo && clear"
Enter
Show

Sleep 600ms
Type "mcp-testmate init --url http://127.0.0.1:7399/mcp"
Sleep 400ms
Enter
Sleep 6s
